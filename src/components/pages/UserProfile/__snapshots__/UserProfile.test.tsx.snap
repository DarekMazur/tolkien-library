  margin-left: 2px;
}

.emotion-31 .MuiChip-icon {
  margin-left: 4px;
}

.emotion-31 .MuiChip-iconSmall {
  margin-left: 2px;
}

.emotion-31 .MuiChip-deleteIcon {
  margin-right: 5px;
}

.emotion-31 .MuiChip-deleteIconSmall {
  margin-right: 3px;
}

.emotion-31.MuiChip-clickable:hover {
  background-color: rgba(29, 38, 59, 0.04);
}

.emotion-31.Mui-focusVisible {
  background-color: rgba(29, 38, 59, 0.12);
}

.emotion-31 .MuiChip-deleteIcon {
  color: rgba(29, 38, 59, 0.7);
}

.emotion-31 .MuiChip-deleteIcon:hover,
.emotion-31 .MuiChip-deleteIcon:active {
  color: #1D263B;
}

.emotion-32 {
  overflow: hidden;
  text-overflow: ellipsis;
  padding-left: 12px;
  padding-right: 12px;
  white-space: nowrap;
  padding-left: 11px;
  padding-right: 11px;
  padding-left: 8px;
  padding-right: 8px;
  padding-left: 7px;
  padding-right: 7px;
}

